# Sensitive files
.env
.env.local
*.env

# API keys and secrets
*api_key*
*secret*
firecrawl_config.sh

# Claude files
.claude/settings.local.json

# MCP config
.mcp.json

# Scripts with sensitive data
scripts/*_local.sh

# macOS files
.DS_Store

# Obsidian workspace state (device-specific)
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Node modules - always exclude from repo
node_modules/
.node_modules/
pnpm-lock.yaml

# Temporary directories
.tmp/
.worktrees/

# Never commit real API keys
*_API_KEY